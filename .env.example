# 项目配置文件
# 生成方式: Django 项目密钥，可通过 python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())' 生成
SECRET_KEY=your-secret-key-here

# 环境配置: dev (开发环境) 或 prod (生产环境)
ENV=prod

# 调试模式: 0 (关闭) 或 1 (开启)
DEBUG=0

# 数据库连接 URL
# 格式: mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql://root:123456@localhost:3306/seckill_db

# Redis 连接 URL
# 格式: redis://主机:端口/数据库编号
REDIS_URL=redis://localhost:6379/0

# MySQL 配置
MYSQL_ROOT_PASSWORD=123456      # MySQL 根密码
MYSQL_DATABASE=seckill_db        # 数据库名称
MYSQL_USER=root                  # 数据库用户名
MYSQL_PASSWORD=123456            # 数据库密码
MYSQL_HOST=localhost             # 数据库主机
MYSQL_PORT=3306                  # 数据库端口

# 生产环境配置 (仅在 ENV=prod 时生效)
# 静态文件收集目录
STATIC_ROOT=/app/static
# 媒体文件目录
MEDIA_ROOT=/app/media

# Celery 配置
# 与 REDIS_URL 保持一致
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
